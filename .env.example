# Copy this file to .env and fill in your keys
# Never commit your actual .env file

# Groq API key — get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# STT backend: groq (default, uses Groq Whisper API) | local (uses faster-whisper, no API)
STT_BACKEND=groq

# LLM model for the coding agent (Groq free-tier models)
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
AGENT_MODEL=llama-3.3-70b-versatile

# Recording mode: continuous (VAD auto-detect) | ptt (push-to-talk with spacebar)
RECORD_MODE=continuous

# VAD aggressiveness: 0 (least) to 3 (most). Higher = filters more background noise.
VAD_AGGRESSIVENESS=2

# Seconds of silence before recording stops (continuous mode)
SILENCE_TIMEOUT=1.5

# Microphone sample rate (Hz) — 16000 recommended for Whisper
SAMPLE_RATE=16000
