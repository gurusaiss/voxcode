# Copy this file to .env and fill in your keys
# Never commit your actual .env file

# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key — get a free key at https://console.groq.com (no credit card)
GROQ_API_KEY=your_groq_api_key_here

# ── STT & LLM ─────────────────────────────────────────────────────────────────

# STT backend: groq (default, Groq Whisper ~200ms) | local (faster-whisper, offline)
STT_BACKEND=groq

# LLM model for the coding agent
# Fast:    llama-3.1-8b-instant      (lower quality, very fast)
# Default: llama-3.3-70b-versatile   (best quality, still fast on Groq)
AGENT_MODEL=llama-3.3-70b-versatile

# ── Recording ─────────────────────────────────────────────────────────────────

# Recording mode: continuous (VAD auto-detect, fully hands-free) | ptt (hold SPACE)
RECORD_MODE=continuous

# VAD aggressiveness: 0 (permissive) to 3 (strict)
# Increase to 3 if background noise triggers false recordings
# Decrease to 1 if your voice isn't being detected
VAD_AGGRESSIVENESS=2

# Seconds of silence after speech ends before sending (1.0 = snappy, 1.5 = comfortable)
SILENCE_TIMEOUT=1.0

# Microphone sample rate in Hz — 16000 is required for Whisper
SAMPLE_RATE=16000

# ── Troubleshooting ───────────────────────────────────────────────────────────

# If the wrong microphone is selected, run:
#   python -m voice_agent --list-devices
# Then set:
#   DEVICE_INDEX=2   (replace 2 with your device number)
# DEVICE_INDEX=

# If the bar stays empty and speech is never detected, your mic level may be low.
# Try increasing mic volume in your OS sound settings, or lower VAD aggressiveness:
#   VAD_AGGRESSIVENESS=1
